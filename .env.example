# WorkHub — Environment Variables
# Copy to .env and fill in actual values

# Azure AD App Registration
VITE_CLIENT_ID=
VITE_AUTHORITY=https://login.microsoftonline.com/common

# Dataverse
VITE_DATAVERSE_URL=
VITE_DATAVERSE_ORG_URL=
VITE_DATAVERSE_SCOPE=

# Sensitive IDs (do NOT commit actual values)
VITE_AZURE_SUBSCRIPTION_ID=
VITE_PP_ENV_ID=
VITE_TENANT_ID=

# Employee (optional, for dev)
VITE_EMPLOYEE_ID=
